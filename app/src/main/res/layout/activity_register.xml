<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/main"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@color/lightGrey"
tools:context=".Activity.MainActivity">


<ScrollView
    android:id="@+id/homeScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="28dp"
        android:padding="24dp"
        android:paddingBottom="100dp">

<!--        <LinearLayout-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="match_parent"-->
<!--            android:layout_marginHorizontal="24dp"-->
<!--            android:layout_marginTop="28dp"-->
<!--            android:orientation="horizontal">-->

            <ImageView
                android:id="@+id/back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="backBtn3"
                app:srcCompat="@drawable/back"
                tools:ignore="OnClick,SpeakableTextPresentCheck,TouchTargetSizeCheck" />


            <!-- Login Title -->
            <TextView
                android:id="@+id/tvLoginTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="40dp"
                android:layout_marginHorizontal="100dp"
                android:layout_marginBottom="40dp"
                android:textColor="#000000" />

            <EditText
                android:id="@+id/etname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#CCCCCC"
                android:drawableStart="@drawable/ic_user"
                android:drawablePadding="10dp"
                android:hint="Type your name"
                android:inputType="text"
                android:minHeight="48dp"
                android:paddingStart="10dp"
                android:textColor="#000000" />

            <!-- Username Input -->
            <EditText
                android:id="@+id/etemail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#CCCCCC"
                android:drawableStart="@drawable/ic_user"
                android:drawablePadding="10dp"
                android:hint="Type your email"
                android:inputType="text"
                android:minHeight="48dp"
                android:paddingStart="10dp"
                android:textColor="#000000" />

            <!-- Password Input -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#BAB9B9"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="10dp"
                android:hint="Type your password"
                android:inputType="textPassword"
                android:minHeight="48dp"
                android:paddingStart="10dp"
                android:textColor="#000000" />

            <EditText
                android:id="@+id/etRePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#BAB9B9"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="10dp"
                android:hint="Type your Re-password"
                android:inputType="textPassword"
                android:minHeight="48dp"
                android:paddingStart="10dp"
                android:textColor="#000000" />

            <EditText
                android:id="@+id/etnumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#BAB9B9"
                android:paddingLeft="40dp"
                android:gravity="start"
                android:drawableStart="@drawable/number"
                android:drawablePadding="10dp"
                android:hint="Type your number"
                android:inputType="number"
                android:minHeight="48dp"
                android:paddingStart="10dp"
                android:textColor="#000000" />


            <!-- Login Button -->
            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SignUp"
                android:textStyle="bold"
                android:textSize="18dp"
                android:layout_marginTop="60dp"
                android:textAllCaps="true"
                android:textColor="#FFFFFF" />

        </LinearLayout>

</ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>